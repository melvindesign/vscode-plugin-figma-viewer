# Copiez ce fichier en `.env` (gitignoré) et renseignez vos identifiants.
# Créez une app OAuth *privée* sur https://www.figma.com/developers/apps
# (le scope `projects:read`, requis ici, n'existe que pour les apps privées,
#  et doit être ACTIVÉ dans la configuration de l'app).
# Redirect URL à déclarer dans l'app : http://localhost:53111/callback

FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=

# Optionnel — doit correspondre au port de la Redirect URL ci-dessus (défaut: 53111)
FIGMA_CALLBACK_PORT=53111

# Optionnel — scopes OAuth demandés (défaut: projects:read). Doivent être activés
# dans l'app. Séparez par des espaces si plusieurs (ex: projects:read file_metadata:read)
FIGMA_SCOPES=projects:read
